<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spring.boot.hole.dao.mapper.ExampleTableMapper">
    <select id="getListByColumn1Name" parameterType="java.lang.String" resultType="com.spring.boot.hole.dao.entity.ExampleTable">
        SELECT id,user_id,zh_name,age,address FROM example_table
        where user_id like concat('%', #{userId}, '%') escape '/'
    </select>
</mapper>

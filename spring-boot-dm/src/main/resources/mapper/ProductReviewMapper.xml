<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spring.boot.dm.dao.mapper.ProductReviewMapper">

    <select id="selectByProductId" parameterType="java.lang.String" resultType="com.spring.boot.dm.dao.entity.ProductReview">
        SELECT
            ID,
            PRODUCT_REVIEWID,
            PRODUCTID,
            NAME,
            REVIEWDATE,
            EMAIL,
            RATING,
            COMMENTS,
            VERSION
        FROM
            CMDB2.PRODUCT_REVIEW
        WHERE
            PRODUCTID = #{productId}
    </select>
</mapper>
